generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Projetos {
  id           Int      @id @default(autoincrement())
  nome         String
  descricao  String
  imagem        String
  tecnologias String[]
  githuburl    String
  liveurl      String
  destaque     Boolean

  @@map("projetos")
}

model Experiencias {
  id Int @id @default(autoincrement())
  titulo String
  empresa String
  periodo String
  localizacao String
  tipo String
  descricao String[]
  tecnologias String[]

  @@map("experiencias")
}

model Cliente {
  id Int @id @default(autoincrement())
  createdAt DateTime @default(now())
  nome String
  responsavel String
  telefone String
  primeiro_contrato DateTime
  validade DateTime
  status_pagamento StatusPagamento
  ultima_atualizacao DateTime @updatedAt
}
enum StatusPagamento {
  ativo
  inadimplente
  cancelado
}